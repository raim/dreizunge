+    const { jobId } = await r.json();
+    for(let i=0;i<4800;i++){
+      await new Promise(res=>setTimeout(res,1500));
+      const j = await (await fetch('/api/job/'+jobId)).json();
+      if(btn && j.step){ btn.title=j.step; }
+      if(j.status==='done'){ data=j.data; break; }
+      if(j.status==='error'){ showToast(t('qc.toast.error')+': '+(j.error||'')); return; }
+    }
+  }catch(e){ showToast(t('qc.toast.failed')+': '+e.message); return; }
+  finally{ if(btn){ btn.disabled=false; btn.innerHTML=old; } }
+  if(!data) return;
+  showToast(t('qc.toast.result',{flagged:data.flagged,checked:data.checked})+(data.cleared?' · '+t('qc.toast.cleared',{n:data.cleared}):''));
+  const affected = data.affected||[];
+  if(APP.lessonData && affected.includes(APP.lessonData.id)){
+    const li = (scope.lessonIdx!==undefined && scope.lessonIdx!==null) ? scope.lessonIdx : null;
+    await loadSaved(APP.lessonData.id);          // re-render chapter page with flags
+    if(li!==null) openLessonEditor(li);           // open editor to confirm fixes
+  } else {
+    loadSavedList();
+  }
+}
