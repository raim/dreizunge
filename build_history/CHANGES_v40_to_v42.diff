+  if(btn){ btn.disabled=true; btn.innerHTML='⏳'; }
+  let data=null;
+  try{
+    const r = await fetch('/api/qc',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(scope)});
