+// ── v41 Topic-ID migration (idempotent, runs every boot) ──────────────
+// Stable tp_ IDs are the canonical reference for chain navigation. Topic
+// *names* are mutable (LLM renames, user edits), so continuedFrom name
+// pointers break. This migration:
+//   • assigns _topicId(name) to any topic lacking an id — assigned ONCE,
+//     then permanent (a later rename must NOT recompute it)
+//   • resolves each topic's continuedFrom NAME to the parent's STORED id,
+//     written to continuedFromId. The continuedFrom name is preserved for
+//     display/back-compat and as a resolution fallback for imports.
+//   • orphaned continuedFrom (no matching topic) → continuedFromId = null + warn
+// CRITICAL: resolves to the parent's stored .id, never _topicId(name) —
+// 16 existing chains point at renamed parents whose stored id differs from
+// the hash of their current name. It NEVER edits storylines[] (chapter
+// arrays already use stored ids and are authoritative, including forks).
+(function migrateTopicRefs() {
+  if (store.schemaVersion < 29) return;
+  const topics = store.topics || [];
+  let changed = 0, assignedIds = 0, orphaned = 0;
+
+  // 1. Ensure every topic has a permanent id (assign once, never recompute).
+  for (const t of topics) {
+    if (!t.id) { t.id = _topicId(t.topic); assignedIds++; changed++; }
+  }
+
+  // 2. name -> topics index. A name can map to several entries across
+  //    language pairs; prefer the parent in the same lang/srcLang as the child.
+  const byName = new Map();
+  for (const t of topics) {
+    const k = (t.topic || '').trim().toLowerCase();
+    if (!byName.has(k)) byName.set(k, []);
+    byName.get(k).push(t);
+  }
+  const idSet = new Set(topics.map(t => t.id));
+  const idToTopic = new Map(topics.map(t => [t.id, t]));
+  const resolveParent = (name, child) => {
+    const cands = byName.get((name || '').trim().toLowerCase()) || [];
+    if (cands.length <= 1) return cands[0] || null;
+    return cands.find(c => (c.lang||'') === (child.lang||'') &&
+                           (c.srcLang||'') === (child.srcLang||'')) || cands[0];
+  };
+
+  // 3. Resolve continuedFrom -> continuedFromId (the parent's STORED id).
+  for (const t of topics) {
+    const cf = t.continuedFrom;
+    let newId = null, orphan = false;
+    if (cf && typeof cf === 'string') {
+      if (cf.startsWith('tp_')) {
+        // Legacy: continuedFrom already holds an id. Adopt it; restore the
+        // human-readable name for display when we can map it back.
+        if (idSet.has(cf)) {
+          newId = cf;
+          const parent = idToTopic.get(cf);
+          if (parent && t.continuedFrom !== parent.topic) { t.continuedFrom = parent.topic; changed++; }
+        } else { orphan = true; }
+      } else {
+        const parent = resolveParent(cf, t);
+        if (parent) newId = parent.id; else orphan = true;
+      }
+    }
+    if (t.continuedFromId !== newId) {
+      t.continuedFromId = newId;
+      changed++;
+      if (orphan) {
+        orphaned++;
+        console.warn(`  ⚠ continuedFrom "${String(cf).slice(0,40)}" for "${t.topic}" → no matching topic, set null`);
+      }
+    }
+  }
+
+  if (changed > 0) {
+    saveStore(store);
+    console.log(`  Topic-ID migration: ${assignedIds} id(s) assigned, ${changed} field(s) updated${orphaned ? `, ${orphaned} orphan(s)` : ''}`);
+  }
+})();
